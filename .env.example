# Copy to .env.local for development. Every variable here is optional —
# the site runs with zero config (seed content, in-memory rate limiting,
# no analytics/error tracking) and each integration goes live the moment
# its variables are set. See SETUP.md for what each one is and how to get it.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sanity CMS (docs + FAQ content, waitlist leads) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=

# --- Upstash Redis (waitlist rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare Turnstile (waitlist bot protection) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Sentry (error tracking) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Plausible (optional cookie-gated analytics; Vercel Analytics is always on) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Feature flags ---
NEXT_PUBLIC_FLAG_INTERACTIVE_DEMO=true
NEXT_PUBLIC_FLAG_ANNOUNCEMENT=true
